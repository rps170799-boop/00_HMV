<Window x:Class="HMVTools.ElectricalRefresherConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HMV Tools - Refresher Configuration"
        Width="500" SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="False"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White"
        FontFamily="Roboto, Arial, Segoe UI">

    <Border Background="White" BorderBrush="#C8C8D2" BorderThickness="1" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>

            <!-- ── Title Bar ── -->
            <Grid Grid.Row="0" MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#004982" Offset="0.0"/>
                        <GradientStop Color="White"   Offset="2.5"/>
                    </LinearGradientBrush>
                </Grid.Background>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="HMV " Foreground="White"   FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text="Ingenieros" Foreground="#E9AA00" FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text=" — Refresher Configuration" Foreground="White"
                               FontSize="10" Margin="5,2,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Content="✕" FontSize="12" Foreground="White"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Click="BtnCancel_Click"/>
            </Grid>

            <!-- ── Body ── -->
            <StackPanel Grid.Row="1" Margin="24,16,24,12">

                <!-- Section A: Adaptive Point Parameters -->
                <Border Background="#F0F6FC" BorderBrush="#C8D8E8" BorderThickness="0,0,0,1"
                        Margin="0,0,0,10" Padding="0,0,0,6">
                    <TextBlock Text="A — Adaptive Point Parameters"
                               FontSize="10" Foreground="#004982" FontWeight="Bold"/>
                </Border>

                <TextBlock Text="1. Connection Number Parameter"
                           FontSize="10" Foreground="#787882" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ComboBox x:Name="cmbCnxNumber" Height="26" FontSize="10" Margin="0,0,0,12"
                          ToolTip="Parameter on the adaptive point that stores the connection ID (e.g. HMV_CFI_CONEXIÓN)"/>

                <TextBlock Text="2. Equipment Name Parameter  (used for Inicial / Final)"
                           FontSize="10" Foreground="#787882" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ComboBox x:Name="cmbEquipoInicial" Height="26" FontSize="10" Margin="0,0,0,12"
                          ToolTip="Parameter on the adaptive point that stores the equipment identifier"/>

                <TextBlock Text="3. Connected Flag Parameter  (Yes/No)"
                           FontSize="10" Foreground="#787882" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ComboBox x:Name="cmbConnected" Height="26" FontSize="10" Margin="0,0,0,16"
                          ToolTip="Yes/No parameter that marks the point as already connected"/>

                <!-- Section B: FlexPipe Parameters -->
                <Border Background="#FFF8E8" BorderBrush="#E8D8A0" BorderThickness="0,0,0,1"
                        Margin="0,0,0,10" Padding="0,0,0,6">
                    <TextBlock Text="B — FlexPipe Parameters"
                               FontSize="10" Foreground="#A07000" FontWeight="Bold"/>
                </Border>

                <TextBlock Text="4. FlexPipe — Connection Number Parameter"
                           FontSize="10" Foreground="#787882" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ComboBox x:Name="cmbFlexCnxNumber" Height="26" FontSize="10" Margin="0,0,0,12"
                          ToolTip="Parameter on the FlexPipe that stores the connection number (used in Reset to find and delete)"/>

                <TextBlock Text="5. FlexPipe — Equipo Inicial Parameter"
                           FontSize="10" Foreground="#787882" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ComboBox x:Name="cmbFlexInicial" Height="26" FontSize="10" Margin="0,0,0,12"
                          ToolTip="Parameter on the FlexPipe that receives the start equipment name"/>

                <TextBlock Text="6. FlexPipe — Equipo Final Parameter"
                           FontSize="10" Foreground="#787882" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ComboBox x:Name="cmbFlexFinal" Height="26" FontSize="10" Margin="0,0,0,16"
                          ToolTip="Parameter on the FlexPipe that receives the end equipment name"/>

                <!-- Section C: Types -->
                <Border Background="#F4F4F8" BorderBrush="#C8C8D2" BorderThickness="0,0,0,1"
                        Margin="0,0,0,10" Padding="0,0,0,6">
                    <TextBlock Text="C — MEP Types"
                               FontSize="10" Foreground="#3C3C5C" FontWeight="Bold"/>
                </Border>

                <TextBlock Text="7. FlexPipe Type"
                           FontSize="10" Foreground="#787882" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ComboBox x:Name="cmbFlexPipeType" Height="26" FontSize="10" Margin="0,0,0,12"
                          ToolTip="FlexPipe type from the model (FamilyName : TypeName)"/>

                <TextBlock Text="8. Electrical System Type  (PipingSystemType)"
                           FontSize="10" Foreground="#787882" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ComboBox x:Name="cmbSystemType" Height="26" FontSize="10" Margin="0,0,0,16"
                          ToolTip="Piping system type used when creating the FlexPipe"/>

                <!-- Section D: DXF Folder -->
                <Border Background="#F0F6FC" BorderBrush="#C8D8E8" BorderThickness="0,0,0,1"
                        Margin="0,0,0,10" Padding="0,0,0,6">
                    <TextBlock Text="D — DXF Source"
                               FontSize="10" Foreground="#004982" FontWeight="Bold"/>
                </Border>

                <TextBlock Text="9. DXF Folder"
                           FontSize="10" Foreground="#787882" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="70"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtDxfFolder" Height="26" FontSize="10"
                             VerticalContentAlignment="Center" IsReadOnly="True" Padding="4,0"/>
                    <Button Grid.Column="1" Content="Browse" FontSize="10" Height="26" Margin="5,0,0,0"
                            Background="#004982" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="BtnBrowse_Click"/>
                </Grid>

            </StackPanel>

            <!-- ── Footer ── -->
            <StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Margin="0,0,20,0">
                <Button Content="Cancel" FontSize="10" Height="30" Width="80"
                        Background="#F0F0F3" Foreground="#3C3C3C" BorderThickness="0"
                        Cursor="Hand" Margin="0,0,10,0" Click="BtnCancel_Click"/>
                <Button Content="Save" FontSize="10" FontWeight="Bold"
                        Height="30" Width="80"
                        Background="#E9AA00" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="BtnSave_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
