<Window x:Class="HMVTools.ElectricalFlowConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HMV Tools - Flow Configuration"
        Height="225" Width="460"
        WindowStyle="None"
        AllowsTransparency="False"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White"
        FontFamily="Roboto, Arial, Segoe UI">

    <Border Background="White" BorderBrush="#C8C8D2" BorderThickness="1" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>

            <!-- ── Title Bar ── -->
            <Grid Grid.Row="0" MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#004982" Offset="0.0"/>
                        <GradientStop Color="White"   Offset="2.5"/>
                    </LinearGradientBrush>
                </Grid.Background>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="HMV " Foreground="White"   FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text="Ingenieros" Foreground="#E9AA00" FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text=" - Flow Configuration" Foreground="White"
                               FontSize="10" Margin="5,2,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="1" Content="✕" FontSize="12" Foreground="White"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Click="BtnCancel_Click"/>
            </Grid>

            <!-- ── Body ── -->
            <StackPanel Grid.Row="1" Margin="24,16,24,8">

                <!-- 1. Source parameter on Equipment -->
                <TextBlock Text="1. Source Parameter (from Electrical Equipment)"
                           FontSize="10" Foreground="#787882" FontWeight="SemiBold"
                           Margin="0,0,0,4"/>
                <ComboBox x:Name="cmbSourceEquipParam"
                          Height="26" FontSize="10" Margin="0,0,0,14"
                          IsEditable="True"
                          ToolTip="The parameter read from the closest Electrical Equipment (Type or Instance)"/>

                <!-- 2. Destination parameter on Adaptive Point -->
                <TextBlock Text="2. Destination Parameter (on Adaptive Point)"
                           FontSize="10" Foreground="#787882" FontWeight="SemiBold"
                           Margin="0,0,0,4"/>
                <ComboBox x:Name="cmbDestPointParam"
                          Height="26" FontSize="10" Margin="0,0,0,14"
                          IsEditable="True"
                          ToolTip="Writable instance parameter on the Adaptive Point that receives the equipment value"/>

                
               
            </StackPanel>

            <!-- ── Footer ── -->
            <StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Margin="0,0,20,0">

                <Button Content="Cancel" FontSize="10" Height="30" Width="80"
                        Background="#F0F0F3" Foreground="#3C3C3C" BorderThickness="0"
                        Cursor="Hand" Margin="0,0,10,0" Click="BtnCancel_Click"/>

                <Button Content="Save" FontSize="10" FontWeight="Bold"
                        Height="30" Width="80"
                        Background="#E9AA00" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="BtnSave_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
