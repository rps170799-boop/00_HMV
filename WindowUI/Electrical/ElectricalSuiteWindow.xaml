<Window x:Class="HMVTools.ElectricalSuiteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HMV Tools - Electrical Suite"
        Width="296" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        FontFamily="Roboto, Arial, Segoe UI">

    <Border Background="White" BorderBrush="#C8C8D2" BorderThickness="1" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#004982" Offset="0.0"/>
                        <GradientStop Color="White" Offset="2.5"/>
                    </LinearGradientBrush>
                </Grid.Background>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="HMV " Foreground="White" FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text="Ingenieros" Foreground="#E9AA00" FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text=" | Electrical Suite" Foreground="White" FontSize="10" Margin="5,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="✕" Click="BtnClose_Click"
                        Background="Transparent" Foreground="White"
                        BorderThickness="0" Width="50" FontSize="14" Cursor="Hand"/>
            </Grid>

            <!-- Tool buttons -->
            <StackPanel Grid.Row="1" Margin="20,18,20,14">

                <!-- 1 Heredate Parameter -->
                <Button x:Name="BtnFlow" Click="BtnFlow_Click"
                        Height="60" Margin="0,0,0,10"
                        Background="#F5F8FC" BorderBrush="#C8C8D2" BorderThickness="1"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E6F0FA"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#CCE0F5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="6" Background="#004982" CornerRadius="3,0,0,3"
                                Margin="0,8,0,8"/>
                        <StackPanel VerticalAlignment="Center" Margin="14,0,0,0">
                            <TextBlock Text="1 — Heredate Parameter"
                                       Foreground="#004982" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="Assign equipment param to adaptive points"
                                       Foreground="#787882" FontSize="9"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <!-- 2 Export Information -->
                <Button x:Name="BtnGeom" Click="BtnGeom_Click"
                        Height="60" Margin="0,0,0,10"
                        Background="#F5F8FC" BorderBrush="#C8C8D2" BorderThickness="1"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E6F0FA"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#CCE0F5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="6" Background="#E9AA00" CornerRadius="3,0,0,3"
                                Margin="0,8,0,8"/>
                        <StackPanel VerticalAlignment="Center" Margin="14,0,0,0">
                            <TextBlock Text="2 — Export Information"
                                       Foreground="#004982" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="Compare FlexPipe geometry with DXF files"
                                       Foreground="#787882" FontSize="9"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <!-- 3 Refresh Connections (disabled) -->
                <Button x:Name="BtnRefresh" Click="BtnRefresh_Click"
                        Height="60"
                        Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="1"
                        Cursor="Arrow" IsEnabled="False">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="6" Background="#C8C8D2" CornerRadius="3,0,0,3"
                                Margin="0,8,0,8"/>
                        <StackPanel VerticalAlignment="Center" Margin="14,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="3 — Refresh Connections"
                                           Foreground="#ABABAB" FontSize="12" FontWeight="SemiBold"/>
                                <Border Background="#FFF8E1" BorderBrush="#E9AA00"
                                        BorderThickness="1" CornerRadius="3"
                                        Margin="10,0,0,0" Padding="5,1">
                                    <TextBlock Text="coming soon"
                                               Foreground="#E9AA00" FontSize="8"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="Rebuild electrical pipe connections"
                                       Foreground="#C8C8D2" FontSize="9"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

            </StackPanel>

            <!-- Status bar -->
            <Border Grid.Row="2" Background="#F0F0F3" BorderBrush="#C8C8D2" BorderThickness="0,1,0,0" Padding="20,0">
                <TextBlock x:Name="txtStatus" Text="Select a tool to begin."
                           Foreground="#787882" FontSize="9" VerticalAlignment="Center"/>
            </Border>

        </Grid>
    </Border>
</Window>