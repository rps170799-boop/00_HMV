<Window x:Class="HMVTools.ElectricalGeometryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HMV Tools - Electrical Geometry"
        Height="420" Width="460"
        WindowStyle="None" 
        AllowsTransparency="False" 
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="White"
        FontFamily="Roboto, Arial, Segoe UI">

    <Border Background="White" BorderBrush="#C8C8D2" BorderThickness="1" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#004982" Offset="0.0"/>
                        <GradientStop Color="White" Offset="2.5"/>
                    </LinearGradientBrush>
                </Grid.Background>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="HMV " Foreground="White" FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text="Ingenieros" Foreground="#E9AA00" FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text=" - Electrical Geometry" Foreground="White" FontSize="10" Margin="5,2,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Content="✕" FontSize="12" Foreground="White"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Click="BtnClose_Click"/>
            </Grid>

            <!-- Controls -->
            <StackPanel Grid.Row="1" Margin="20,15,20,10">

                <TextBlock Text="1. Target Parameter Name" FontSize="10" Foreground="#787882" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ComboBox x:Name="cmbParameter" Height="24" FontSize="10" IsEditable="True"
                          MaxDropDownHeight="120"
                          VerticalContentAlignment="Center" Padding="4,0" Margin="0,0,0,12"/>

                <CheckBox x:Name="chkIncludeDxf" Content="Include .DXF info exportation?" FontSize="10"
                          Foreground="#3C3C3C" Margin="0,0,0,8"
                          Checked="ChkIncludeDxf_Changed" Unchecked="ChkIncludeDxf_Changed"/>

                <StackPanel x:Name="pnlDxf" Visibility="Collapsed">
                    <TextBlock Text="2. DXF Folder Location" FontSize="10" Foreground="#787882" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtFolder" Height="24" FontSize="10"
                                 VerticalContentAlignment="Center" IsReadOnly="True" Padding="4,0"/>
                        <Button Grid.Column="1" Content="Browse" FontSize="10" Height="24" Margin="5,0,0,0"
                                Background="#004982" Foreground="White" BorderThickness="0"
                                Cursor="Hand" Click="BtnBrowse_Click"/>
                    </Grid>
                </StackPanel>

            </StackPanel>

            <!-- Status log -->
            <Border Grid.Row="2" Margin="20,0,20,10" BorderBrush="#C8C8D2" BorderThickness="1">
                <TextBox x:Name="txtStatus"
                         FontSize="10" Foreground="#3C3C3C"
                         Background="#F8F8FB"
                         IsReadOnly="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         BorderThickness="0" Padding="6,4"
                         Text="Ready."/>
            </Border>

            <!-- Buttons -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Center" Margin="0,0,20,0">
                <Button Content="Close" FontSize="10" Height="30" Width="80"
                        Background="#F0F0F3" Foreground="#3C3C3C" BorderThickness="0"
                        Cursor="Hand" Margin="0,0,10,0" Click="BtnClose_Click"/>
                <Button Content="Generate Report" FontSize="10" FontWeight="Bold"
                        Height="30" Width="120" Background="#E9AA00" Foreground="White"
                        BorderThickness="0" Cursor="Hand" Click="BtnGenerate_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
