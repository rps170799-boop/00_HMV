<Window x:Class="HMVTools.ElectricalFlowWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HMV Tools - Electrical Flow"
        Height="360" Width="480"
        WindowStyle="None"
        AllowsTransparency="False"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="White"
        FontFamily="Roboto, Arial, Segoe UI">

    <Border Background="White" BorderBrush="#C8C8D2" BorderThickness="1" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>

            <!-- ── Title Bar ── -->
            <Grid Grid.Row="0" MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#004982" Offset="0.0"/>
                        <GradientStop Color="White"   Offset="2.5"/>
                    </LinearGradientBrush>
                </Grid.Background>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="HMV " Foreground="White"   FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text="Ingenieros" Foreground="#E9AA00" FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text=" - Electrical Flow · Equipment Injection" Foreground="White"
                               FontSize="10" Margin="5,2,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="1" Content="✕" FontSize="12" Foreground="White"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Click="BtnClose_Click"/>
            </Grid>

            <!-- ── Body ── -->
            <StackPanel Grid.Row="1" Margin="24,18,24,8" VerticalAlignment="Center">

                <!-- Selection row -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" BorderBrush="#C8C8D2" BorderThickness="1"
                            CornerRadius="2" Padding="8,0" Height="26" Margin="0,0,8,0">
                        <TextBlock x:Name="txtPointCount"
                                   Text="No points selected"
                                   FontSize="10" Foreground="#5A5A6A"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <Button Grid.Column="1" Content="⊕ Select Points" FontSize="10"
                            Height="26" Padding="10,0" Margin="0,0,6,0"
                            Background="#004982" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="BtnPick_Click"
                            ToolTip="Pick adaptive components in the model"/>

                    <Button Grid.Column="2" Content="✕ Clear" FontSize="10"
                            Height="26" Padding="8,0"
                            Background="#E8E8F0" Foreground="#3C3C3C" BorderThickness="0"
                            Cursor="Hand" Click="BtnClearPoints_Click"
                            ToolTip="Clear current selection"/>
                </Grid>

                <!-- Status / Log area -->
                <TextBox x:Name="txtStatus"
                         Text="Ready. Select points then click Inject Parameters."
                         FontSize="9" Foreground="#004982" FontWeight="SemiBold"
                         FontFamily="Consolas, Courier New"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         AcceptsReturn="True"
                         Height="140"
                         BorderThickness="1" BorderBrush="#C8C8D2"
                         Padding="6,4"
                         Background="#F7F7FB"/>
            </StackPanel>

            <!-- ── Footer buttons ── -->
            <StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Margin="0,0,20,0">

                <Button Content="⚙ Config" FontSize="10" Height="30" Padding="14,0"
                        Background="#5A7FA8" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Margin="0,0,10,0" Click="BtnConfig_Click"
                        ToolTip="Set source and destination parameters"/>

                <Button Content="Cancel" FontSize="10" Height="30" Width="70"
                        Background="#F0F0F3" Foreground="#3C3C3C" BorderThickness="0"
                        Cursor="Hand" Margin="0,0,10,0" Click="BtnClose_Click"/>

                <Button Content="Inject Parameters" FontSize="10" FontWeight="Bold"
                        Height="30" Padding="14,0"
                        Background="#E9AA00" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="BtnInject_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

