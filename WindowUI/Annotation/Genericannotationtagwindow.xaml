<Window x:Class="HMVTools.GenericAnnotationTagWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HMV Tools - Generic Annotation Tag" 
        Height="600" Width="500"
        WindowStyle="None" AllowsTransparency="True" 
        Background="Transparent" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Border Background="#F5F5F8" BorderBrush="#C8C8D2" BorderThickness="1" >
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="9*"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="438*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" MouseLeftButtonDown="TopBar_MouseLeftButtonDown" Grid.ColumnSpan="3">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#004982" Offset="0.0"/>
                        <GradientStop Color="White" Offset="2.5"/>
                    </LinearGradientBrush>
                </Grid.Background>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="19*"/>
                    <ColumnDefinition Width="390*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="2,0,0,0" Grid.Column="1">
                    <TextBlock Text="HMV " Foreground="White" FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text="Ingenieros" Foreground="#E9AA00" FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text=" - Generic Annotation Tag" Foreground="White" FontSize="10" Margin="5,2,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="2" Content="✕" Width="40" Background="Transparent" Foreground="#3C3C3C" 
                        BorderThickness="0" FontSize="14" Cursor="Hand" Click="BtnClose_Click"/>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Grid.ColumnSpan="3">
                <StackPanel Margin="20,10,20,10">

                    <TextBlock Text="1. Select Text Type" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <Border  BorderBrush="#C8C8D2" BorderThickness="1" Background="White" Margin="0,0,0,5">
                        <TextBox x:Name="typeSearchBox" Height="25" BorderThickness="0" FontSize="10" VerticalContentAlignment="Center" 
                                 Padding="5,0" TextChanged="TypeSearchBox_TextChanged"/>
                    </Border>
                    <ListBox x:Name="typeListBox" Height="120" DisplayMemberPath="TypeName" FontSize="10"  Margin="0,0,0,15"/>

                    <TextBlock Text="2. Select Parameter"  FontSize="10" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <Border BorderBrush="#C8C8D2" BorderThickness="1" Background="White" Margin="0,0,0,5">
                        <TextBox x:Name="paramSearchBox" Height="25" BorderThickness="0"  FontSize="10" VerticalContentAlignment="Center" 
                                 Padding="5,0" TextChanged="ParamSearchBox_TextChanged"/>
                    </Border>
                    <ListBox x:Name="paramListBox" FontSize="10" Height="120" Margin="0,0,0,15"/>

                    <TextBlock Text="3. Set Offsets (mm)" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="X Offset:" FontSize="10" Foreground="#666"/>
                            <TextBox x:Name="offsetXBox" FontSize="10" Text="0.0" Height="25" VerticalContentAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Y Offset:" FontSize="10" Foreground="#666"/>
                            <TextBox x:Name="offsetYBox" FontSize="10" Text="0.0" Height="25" VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" CornerRadius="0,0,8,8" Grid.ColumnSpan="3">
                <Button Content="Place Tags" Width="150" Height="40" Background="#E9AA00" Foreground="White" 
                        FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0" Cursor="Hand" Click="BtnApply_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Border>
        </Grid>
    </Border>
</Window>