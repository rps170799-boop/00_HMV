<Window x:Class="HMVTools.GridLevelExtentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HMV Tools - Grid &amp; Level Extent"
        Height="500" Width="500"
        WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        FontFamily="Roboto,Arial, Segoe UI">

	<Border Background="White"  BorderBrush="#C8C8D2" BorderThickness="1" ClipToBounds="True">
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="40"/>
				<RowDefinition Height="*"/>
				<RowDefinition Height="70"/>
			</Grid.RowDefinitions>

			<Grid Grid.Row="0" MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
				<Grid.Background>
					<LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
						<GradientStop Color="#004982 " Offset="0.0"/>
						<GradientStop Color="White" Offset="2.5"/>
					</LinearGradientBrush>
				</Grid.Background>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>

				<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
					<TextBlock Text="HMV " Foreground="White" FontSize="12" FontWeight="Bold"/>
					<TextBlock Text="Ingenieros" Foreground="#E9AA00" FontSize="12" FontWeight="Bold"/>
					<TextBlock Text=" | Grid &amp; Level Extent" Foreground="White" FontSize="10" Margin="5,2,0,0"/>
				</StackPanel>

				<Button Grid.Column="1" Content="✕" Click="BtnClose_Click" Background="Transparent"
                        Foreground="White" BorderThickness="0" Width="50" FontSize="14" Cursor="Hand"/>
			</Grid>

			<Grid Grid.Row="1" Margin="20,15,20,10">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<StackPanel Grid.Row="0" Margin="0,0,0,12">
					<TextBlock Text="Conversion Mode" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,6" Foreground="#1E1E1E"/>
					<StackPanel Orientation="Horizontal">
						<RadioButton x:Name="radio2D" Content="2D — ViewSpecific" IsChecked="True" GroupName="Mode" FontSize="10" Margin="0,0,16,0" Cursor="Hand"/>
						<RadioButton x:Name="radio3D" Content="3D — Model" GroupName="Mode" FontSize="10" Cursor="Hand"/>
					</StackPanel>
				</StackPanel>

				<StackPanel Grid.Row="1" Margin="0,0,0,12">
					<TextBlock Text="Elements to Process" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,6" Foreground="#1E1E1E"/>
					<StackPanel Orientation="Horizontal">
						<CheckBox x:Name="chkGrids" Content="Grids" IsChecked="True" FontSize="10" Margin="0,0,24,0" Cursor="Hand"/>
						<CheckBox x:Name="chkLevels" Content="Levels" IsChecked="True" FontSize="10" Cursor="Hand"/>
					</StackPanel>
				</StackPanel>

				<DockPanel Grid.Row="2" Margin="0,0,0,4">
					<TextBlock Text="Views" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#1E1E1E"/>
					<TextBlock x:Name="countText" FontSize="10" Foreground="#787882" HorizontalAlignment="Right" VerticalAlignment="Center" DockPanel.Dock="Right"/>
				</DockPanel>

				<Border Grid.Row="3" CornerRadius="8" BorderBrush="#C8C8D2" BorderThickness="1" Background="White" Margin="0,0,0,8">
					<TextBox x:Name="searchBox" Height="20" FontSize="10" VerticalContentAlignment="Center" BorderThickness="0" Background="Transparent" Padding="10,0,10,0" TextChanged="SearchBox_TextChanged"/>
				</Border>

				<Border Grid.Row="4" Height="150" CornerRadius="8" BorderBrush="#C8C8D2" BorderThickness="1" Background="White" Margin="0,5,0,0
						">
					<ListBox x:Name="viewList" BorderThickness="0" Background="Transparent" FontSize="10" Padding="4"/>
				</Border>

				<Button Grid.Row="5" Content="Select ALL Views" FontSize="10 
						" Background="#F0F0F3" Foreground="#3C3C3C" BorderThickness="0" Cursor="Hand" Margin="0,10,0,0" Click="SelectAllViews_Click" Height="28" VerticalAlignment="Top">
					<Button.Resources>
						<Style TargetType="Border">
							<Setter Property="CornerRadius" Value="6"/>
						</Style>
					</Button.Resources>
				</Button>

				<TextBlock Grid.Row="6" FontSize="8" Foreground="#787882" TextWrapping="Wrap" Margin="0,4,0,0">
					2D (ViewSpecific): each view controls its own grid/level extents independently.<LineBreak/>
					3D (Model): moving an extent in one view affects all views.
				</TextBlock>
			</Grid>

			<StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
				<Button Content="Cancel"  FontSize="10" Height="30" Width="150" Background="#F0F0F3" Foreground="#3C3C3C" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0" Click="BtnCancel_Click">
					<Button.Resources>
						<Style TargetType="Border">
							<Setter Property="CornerRadius" Value="6"/>
						</Style>
					</Button.Resources>
				</Button>

				<Button Content="Execute" FontSize="10" Height="30" Width="150" Background="#E9AA00" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Click="BtnExecute_Click">
					<Button.Resources>
						<Style TargetType="Border">
							<Setter Property="CornerRadius" Value="6"/>
						</Style>
					</Button.Resources>
				</Button>
			</StackPanel>
		</Grid>
	</Border>
</Window>