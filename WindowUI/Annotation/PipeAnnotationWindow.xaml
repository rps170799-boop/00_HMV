<Window x:Class="HMVTools.PipeAnnotationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HMV Tools - Pipe Annotation"
        Height="500" Width="500"
        WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        FontFamily="Roboto,Arial, Segoe UI">

    <Border Background="White" BorderBrush="#C8C8D2" BorderThickness="1" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#004982" Offset="0.0"/>
                        <GradientStop Color="White" Offset="2.5"/>
                    </LinearGradientBrush>
                </Grid.Background>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="HMV " Foreground="White" FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text="Ingenieros" Foreground="#E9AA00" FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text=" | Annotation through linear based Family" Foreground="White" FontSize="10" Margin="5,2,0,0"/>
                </StackPanel>

                <Button Grid.Column="1" Content="✕" Click="BtnClose_Click" Background="Transparent" 
                        Foreground="White" BorderThickness="0" Width="50" FontSize="14" Cursor="Hand"/>
            </Grid>

            <Grid Grid.Row="1" Margin="20,20,20,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border x:Name="annotBtnBorder" Grid.Column="0" Height="30" CornerRadius="6" Background="#004982" Cursor="Hand" MouseLeftButtonDown="AnnotBtn_Click">
                        <TextBlock x:Name="annotBtnText" Text="Generic Annotation" Foreground="White" FontWeight="SemiBold" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <Border x:Name="detailBtnBorder" Grid.Column="2" Height="30" CornerRadius="6" Background="#F0F0F3" Cursor="Hand" MouseLeftButtonDown="DetailBtn_Click">
                        <TextBlock x:Name="detailBtnText" Text="Detail Item" Foreground="#3C3C3C" FontWeight="Normal" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>

                <Border Grid.Row="1" CornerRadius="8" BorderBrush="#C8C8D2" BorderThickness="1" Background="White" Margin="0,0,0,10">
                    <TextBox x:Name="searchBox" Height="28" FontSize="10" VerticalContentAlignment="Center" BorderThickness="0" Background="Transparent" Padding="10,0,10,0" TextChanged="SearchBox_TextChanged"/>
                </Border>

                <Border Grid.Row="2" CornerRadius="8" BorderBrush="#C8C8D2" BorderThickness="1" Background="White" Margin="0,0,0,10">
                    <ListBox x:Name="listBox" BorderThickness="0" Background="Transparent" FontSize="10" Padding="4"/>
                </Border>

                <StackPanel x:Name="spacingPanel" Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
                    <TextBlock Text="Spacing (mm):" FontSize="10" Foreground="#1E1E1E" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Border CornerRadius="4" BorderBrush="#C8C8D2" BorderThickness="1" Background="White" Width="80" Height="24">
                        <TextBox x:Name="spacingBox" Text="2000" FontSize="10" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" BorderThickness="0" Background="Transparent"/>
                    </Border>
                </StackPanel>

                <Border x:Name="warningBorder" Grid.Row="4" Background="#FFF4CE" BorderBrush="#F5C042" BorderThickness="1" CornerRadius="4" Padding="8" Visibility="Collapsed">
                    <TextBlock x:Name="warningText" Text="Warning message" Foreground="#9C6500" FontSize="10" TextWrapping="Wrap"/>
                </Border>
            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                <Button Content="Cancel" FontSize="10   " Height="30" Width="150" Background="#F0F0F3" Foreground="#3C3C3C" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0" Click="BtnCancel_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Execute" FontSize="10" FontWeight="SemiBold" Height="30" Width="150" Background="#E9AA00" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnExecute_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>