<Window x:Class="HMVTools.AutoDimensionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HMV Tools - Auto Dimension"
        Height="220" Width="500
        "
        WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        FontFamily="Roboto,Arial, Segoe UI">

    <Border Background="White" BorderBrush="#C8C8D2" BorderThickness="1" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#004982" Offset="0.0"/>
                        <GradientStop Color="White" Offset="2.5"/>
                    </LinearGradientBrush>
                </Grid.Background>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="HMV " Foreground="White" FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text="Ingenieros" Foreground="#E9AA00" FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text=" | Auto Dimension" Foreground="White" FontSize="10" Margin="5,2,0,0"/>
                </StackPanel>

                <Button Grid.Column="1" Content="✕" Click="BtnClose_Click" Background="Transparent"
                        Foreground="White" BorderThickness="0" Width="50" FontSize="14" Cursor="Hand"/>
            </Grid>

            <Grid Grid.Row="1" Margin="20,15,20,10">
                <StackPanel Margin="0,10,0,0">
                    <TextBlock Text="Tolerance (cm)" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,6" Foreground="#1E1E1E"/>
                    <TextBlock Text="Distances smaller than this will be skipped (merged to the next reference)." FontSize="9" Foreground="#787882" TextWrapping="Wrap" Margin="0,0,0,6"/>
                    <Border CornerRadius="8" BorderBrush="#C8C8D2" BorderThickness="1" Background="White" Height="30">
                        <TextBox x:Name="txtTolerance" Text="2.5" FontSize="12" VerticalContentAlignment="Center" BorderThickness="0" Background="Transparent" Padding="10,0,10,0"/>
                    </Border>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                <Button Content="Cancel" FontSize="10" Height="30" Width="150" Background="#F0F0F3" Foreground="#3C3C3C" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0" Click="BtnCancel_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Execute" FontSize="10" Height="30" Width="150" Background="#E9AA00" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnExecute_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>