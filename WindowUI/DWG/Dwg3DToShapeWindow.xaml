<Window x:Class="HMVTools.Dwg3DToShapeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HMV Tools - 3D DWG to Shape"
        Height="500" Width="500"
        WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        FontFamily="Roboto, Arial, Segoe UI">

    <Border Background="White" BorderBrush="#C8C8D2" BorderThickness="1" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>

            <!-- ══ Title bar ══ -->
            <Grid Grid.Row="0" MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#004982" Offset="0.0"/>
                        <GradientStop Color="White" Offset="2.5"/>
                    </LinearGradientBrush>
                </Grid.Background>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="HMV " Foreground="White" FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text="Ingenieros" Foreground="#E9AA00" FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text=" - 3D DWG Converter" Foreground="White" FontSize="10" Margin="5,2,0,0"/>
                </StackPanel>

                <Button Grid.Column="1" Content="✕" Width="40"
                        Background="Transparent" Foreground="#3C3C3C"
                        BorderThickness="0" FontSize="14" Cursor="Hand"
                        Click="BtnClose_Click"/>
            </Grid>

            <!-- ══ Body ══ -->
            <StackPanel Grid.Row="1" Margin="20,18,20,10">

                <!-- Output Mode + Target Category row -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Output Mode:" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#1E1E1E" Margin="0,0,0,4"/>
                        <Border CornerRadius="6" BorderBrush="#C8C8D2" BorderThickness="1"
                                Background="White">
                            <ComboBox x:Name="cmbMode" Height="30" FontSize="10"
                                      BorderThickness="0" Background="Transparent"
                                      Padding="4,0" VerticalContentAlignment="Center"
                                      SelectionChanged="CmbMode_SelectionChanged"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Target Category:" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#1E1E1E" Margin="0,0,0,4"/>
                        <Border CornerRadius="6" BorderBrush="#C8C8D2" BorderThickness="1"
                                Background="White">
                            <ComboBox x:Name="cmbCategory" Height="30" FontSize="10"
                                      BorderThickness="0" Background="Transparent"
                                      Padding="4,0" VerticalContentAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- DWG Import (hidden in Mode C) -->
                <StackPanel x:Name="pnlImport" Margin="0,0,0,14">
                    <TextBlock Text="Source DWG Import / Link:" FontSize="10" FontWeight="SemiBold"
                               Foreground="#1E1E1E" Margin="0,0,0,4"/>
                    <Border CornerRadius="6" BorderBrush="#C8C8D2" BorderThickness="1" Background="White">
                        <ComboBox x:Name="cmbImports" Height="30" FontSize="10"
                                  BorderThickness="0" Background="Transparent"
                                  Padding="4,0" VerticalContentAlignment="Center"
                                  SelectionChanged="CmbImports_SelectionChanged"/>
                    </Border>
                </StackPanel>

                <!-- Source DirectShape (only in Mode C) -->
                <StackPanel x:Name="pnlSourceDs" Margin="0,0,0,14" Visibility="Collapsed">
                    <TextBlock Text="Source DirectShape:" FontSize="11" FontWeight="SemiBold"
                               Foreground="#1E1E1E" Margin="0,0,0,4"/>
                    <Border CornerRadius="6" BorderBrush="#C8C8D2" BorderThickness="1" Background="White">
                        <ComboBox x:Name="cmbSourceDs" Height="30" FontSize="11"
                                  BorderThickness="0" Background="Transparent"
                                  Padding="4,0" VerticalContentAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- Output name -->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="Output Shape / Family Name:" FontSize="10" FontWeight="SemiBold"
                               Foreground="#1E1E1E" Margin="0,0,0,4"/>
                    <Border CornerRadius="6" BorderBrush="#C8C8D2" BorderThickness="1" Background="White">
                        <TextBox x:Name="txtShapeName" Height="26" FontSize="10"
                                 BorderThickness="0" Background="Transparent"
                                 Padding="8,0" VerticalContentAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- Geometry optimization box -->
                <Border CornerRadius="6" BorderBrush="#0078D4" BorderThickness="1"
                        Background="#004982" Padding="15" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Geometry Optimization" FontSize="10" FontWeight="Bold"
                                   Foreground="White" Margin="0,0,0,10"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Min Vol. (cm³)" FontSize="10"
                                           Foreground="White" Margin="0,0,0,4"/>
                                <Border CornerRadius="6" BorderBrush="#C8C8D2" BorderThickness="1" Background="White">
                                    <TextBox x:Name="txtThreshold" Text="1.0" Height="26" FontSize="10"
                                             HorizontalContentAlignment="Center"
                                             VerticalContentAlignment="Center"
                                             BorderThickness="0" Background="Transparent"
                                             PreviewTextInput="NumericOnly"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock Text="Mesh BBox (mm)" FontSize="10"
                                           Foreground="White" Margin="0,0,0,4"/>
                                <Border CornerRadius="6" BorderBrush="#C8C8D2" BorderThickness="1" Background="White">
                                    <TextBox x:Name="txtMaxEdge" Text="50" Height="26" FontSize="10"
                                             HorizontalContentAlignment="Center"
                                             VerticalContentAlignment="Center"
                                             BorderThickness="0" Background="Transparent"
                                             PreviewTextInput="NumericOnly"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Decimation (1=No)" FontSize="10"
                                           Foreground="White" Margin="0,0,0,4"/>
                                <Border CornerRadius="6" BorderBrush="#C8C8D2" BorderThickness="1" Background="White">
                                    <TextBox x:Name="txtDecimate" Text="1" Height="26" FontSize="10"
                                             HorizontalContentAlignment="Center"
                                             VerticalContentAlignment="Center"
                                             BorderThickness="0" Background="Transparent"
                                             PreviewTextInput="NumericOnly"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Checkboxes -->
                <CheckBox x:Name="chkRefPlanes"
                          Content="Create 9 bounding-box reference planes (6 faces + 3 centers)"
                          IsChecked="True" FontSize="10" Foreground="#1E1E1E"
                          FontWeight="SemiBold" Margin="0,0,0,6"
                          Visibility="Collapsed"/>
                <CheckBox x:Name="chkDeleteOriginal"
                          Content="Delete original DWG import after conversion"
                          IsChecked="False" FontSize="10" Foreground="#1E1E1E"
                          FontWeight="SemiBold"/>
            </StackPanel>

            <!-- ══ Footer buttons ══ -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Center" Margin="0,0,20,0">
                <Button Content="Cancel" FontSize="10" Height="30" Width="100"
                        Background="#F0F0F3" Foreground="#3C3C3C" BorderThickness="0"
                        Cursor="Hand" Margin="0,0,10,0" Click="BtnCancel_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Run Conversion" FontSize="10" FontWeight="Bold"
                        Height="30" Width="140" Background="#E9AA00" Foreground="White"
                        BorderThickness="0" Cursor="Hand" Click="BtnRun_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>

        </Grid>
    </Border>
</Window>