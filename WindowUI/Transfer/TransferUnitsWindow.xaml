<Window x:Class="HMVTools.TransferUnitsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HMV Tools - Transfer Units"
        Height="450" Width="500"
        WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        FontFamily="Roboto, Arial, Segoe UI">

    <Border Background="White" BorderBrush="#C8C8D2" BorderThickness="1" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#004982" Offset="0.0"/>
                        <GradientStop Color="White" Offset="2.5"/>
                    </LinearGradientBrush>
                </Grid.Background>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="HMV " Foreground="White" FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text="Ingenieros" Foreground="#E9AA00" FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text=" | Transfer Units" Foreground="White" FontSize="10" Margin="5,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="✕" Width="40" Background="Transparent" Foreground="#3C3C3C"
                        BorderThickness="0" FontSize="14" Cursor="Hand" Click="BtnCancel_Click"/>
            </Grid>

            <Grid Grid.Row="1" Margin="20,14,20,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" CornerRadius="6" Background="#E8F3FF" BorderBrush="#0078D4" BorderThickness="1"
                        Padding="12,8" Margin="0,0,0,14">
                    <TextBlock x:Name="txtSourceInfo" FontSize="11" Foreground="#004982"/>
                </Border>

                <Grid Grid.Row="1" Margin="0,0,0,6">
                    <TextBlock Text="Target Documents:" FontSize="11" FontWeight="SemiBold" Foreground="#1E1E1E" VerticalAlignment="Center"/>
                    <Button x:Name="btnBrowse" Content="Add Files..." HorizontalAlignment="Right" Width="80" Height="24"
                            Background="#0078D4" Foreground="White" BorderThickness="0" FontSize="10" Cursor="Hand" Click="BtnBrowse_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>

                <Border Grid.Row="2" CornerRadius="6" BorderBrush="#C8C8D2" BorderThickness="1" Background="White">
                    <ListBox x:Name="lstTargets" BorderThickness="0" Padding="4" ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Title}" IsChecked="{Binding IsSelected}" FontSize="11" Margin="2,4" Foreground="#3C3C3C"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                <Button Content="Cancel" FontSize="10" Height="30" Width="150" Background="#F0F0F3" Foreground="#3C3C3C"
                        BorderThickness="0" Cursor="Hand" Margin="0,0,10,0" Click="BtnCancel_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Content="Transfer" FontSize="10" FontWeight="Bold" Height="30" Width="150" Background="#E9AA00" Foreground="White"
                        BorderThickness="0" Cursor="Hand" Click="BtnTransfer_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>