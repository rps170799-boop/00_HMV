<Window x:Class="HMVTools.BatchCloudLinkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HMV Tools - Batch Cloud Linker"
        Width="1000" Height="600"
        WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinWidth="750" MinHeight="450"
        Background="Transparent"
        FontFamily="Roboto, Arial, Segoe UI">

    <Border Background="White" BorderBrush="#C8C8D2" BorderThickness="1" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Grid Grid.Row="0" MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#004982" Offset="0.0"/>
                        <GradientStop Color="White" Offset="2.5"/>
                    </LinearGradientBrush>
                </Grid.Background>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="HMV " Foreground="White" FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text="Ingenieros" Foreground="#E9AA00" FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text=" | Batch Cloud Linker" Foreground="White" FontSize="10" Margin="5,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="✕" Width="40" Background="Transparent" Foreground="#3C3C3C"
                        BorderThickness="0" FontSize="14" Cursor="Hand" Click="Cancel_Click"/>
            </Grid>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="20,14,20,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Info banner -->
                <Border Grid.Row="0" CornerRadius="6" Background="#E8F3FF" BorderBrush="#0078D4" BorderThickness="1"
                        Padding="12,6" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Name="HeaderLabel" FontSize="12" FontWeight="SemiBold" Foreground="#004982"
                                   Text="Found 0 RVT files"/>
                        <TextBlock Name="SubHeaderLabel" FontSize="10" Foreground="#004982" Margin="0,2,0,0"
                                   Text="Project / Folder"/>
                    </StackPanel>
                </Border>

                <!-- Search bar -->
                <Border Grid.Row="1" CornerRadius="6" BorderBrush="#C8C8D2" BorderThickness="1"
                        Margin="0,0,0,10" Padding="2">
                    <TextBox Name="SearchBox" 
                             TextChanged="SearchBox_TextChanged"
                             Height="26" FontSize="11"
                             Padding="6,3"
                             BorderThickness="0"
                             Foreground="#3C3C3C"
                             Background="Transparent">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush Stretch="None" AlignmentX="Left" AlignmentY="Center">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="  🔍 Search by file name or folder..." 
                                                                   Foreground="#999999" FontSize="11"
                                                                   FontFamily="Roboto, Arial, Segoe UI"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Border>

                <!-- DataGrid -->
                <Border Grid.Row="2" BorderBrush="#C8C8D2" BorderThickness="1" ClipToBounds="True">
                    <DataGrid Name="FileGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionMode="Extended"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="#F7F9FC"
                              BorderThickness="0"
                              Background="White"
                              RowHeaderWidth="0"
                              FontSize="11"
                              Foreground="#3C3C3C"
                              IsReadOnly="False">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F0F0F3"/>
                                <Setter Property="Foreground" Value="#1E1E1E"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="BorderBrush" Value="#C8C8D2"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="☐"
                                Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                Width="35"/>
                            <DataGridTextColumn Header="File Name"
                                Binding="{Binding Name}"
                                IsReadOnly="True"
                                Width="*"/>
                            <DataGridTextColumn Header="Instances" Binding="{Binding InstanceCount}" Width="80" IsReadOnly="True" />
                            <DataGridTextColumn Header="Folder"
                                Binding="{Binding FolderPath}"
                                IsReadOnly="True"
                                Width="*"/>
                            <DataGridTextColumn Header="Status"
                                Binding="{Binding Status}"
                                IsReadOnly="True"
                                Width="85"/>
                            <DataGridTemplateColumn Header="Placement" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedItem="{Binding Placement, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                  ItemsSource="{Binding PlacementOptionsBinding}"
                                                  BorderThickness="0" Background="Transparent"
                                                  FontSize="11" Margin="2"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <!-- Bottom bar -->
            <Grid Grid.Row="2" Margin="20,0,20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left controls -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Name="CountLabel" Text="0 selected" VerticalAlignment="Center"
                               FontWeight="SemiBold" FontSize="11" Foreground="#1E1E1E" Margin="0,0,12,0"/>
                    <Button Content="Select All" Click="SelectAll_Click"
                            FontSize="10" Height="28" Width="70" Background="#F0F0F3" Foreground="#3C3C3C"
                            BorderThickness="0" Cursor="Hand" Margin="0,0,4,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="Clear" Click="ClearSelection_Click"
                            FontSize="10" Height="28" Width="50" Background="#F0F0F3" Foreground="#3C3C3C"
                            BorderThickness="0" Cursor="Hand" Margin="0,0,12,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <ComboBox Name="BulkPlacementCombo" Width="130" Height="28" VerticalAlignment="Center"
                              FontSize="10" Margin="0,0,4,0"/>
                    <Button Content="Apply" Click="ApplyPlacement_Click"
                            FontSize="10" Height="28" Width="50" Background="#F0F0F3" Foreground="#3C3C3C"
                            BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>

                <!-- Right buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Reload Selected" Click="ReloadSelected_Click"
                            FontSize="10" Height="30" Width="120" Background="#0078D4" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Margin="0,0,6,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="Link Selected" Click="LinkSelected_Click"
                            FontSize="10" FontWeight="Bold" Height="30" Width="120" Background="#E9AA00" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Margin="0,0,6,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="Cancel" Click="Cancel_Click"
                            FontSize="10" Height="30" Width="80" Background="#F0F0F3" Foreground="#3C3C3C"
                            BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>