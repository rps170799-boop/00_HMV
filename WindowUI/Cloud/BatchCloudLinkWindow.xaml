<Window x:Class="HMVTools.BatchCloudLinkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HMV Tools - Batch Cloud Linker"
        Width="950" Height="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinWidth="700" MinHeight="400">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Name="HeaderLabel" FontSize="14" FontWeight="SemiBold"
                       Text="Found 0 RVT files"/>
            <TextBlock Name="SubHeaderLabel" FontSize="11" Foreground="#666666"
                       Text="Project / Folder"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="1"
                  Name="FileGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Extended"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F7F7F7"
                  BorderBrush="#CCCCCC"
                  BorderThickness="1"
                  IsReadOnly="False">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="☐"
                    Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                    Width="35"/>
                <DataGridTextColumn Header="File Name"
                    Binding="{Binding Name}"
                    IsReadOnly="True"
                    Width="*"/>
                <DataGridTextColumn Header="Folder"
                    Binding="{Binding FolderPath}"
                    IsReadOnly="True"
                    Width="*"/>
                <DataGridTemplateColumn Header="Placement" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox SelectedItem="{Binding Placement, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                      ItemsSource="{Binding PlacementOptionsBinding}"
                                      BorderThickness="0"
                                      Margin="2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Bottom bar -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left side: selection controls -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Name="CountLabel" Text="0 selected" VerticalAlignment="Center"
                           FontWeight="SemiBold" Margin="0,0,15,0"/>
                <Button Content="Select All" Click="SelectAll_Click"
                        Padding="10,4" Margin="0,0,5,0"/>
                <Button Content="Clear" Click="ClearSelection_Click"
                        Padding="10,4" Margin="0,0,15,0"/>
                <ComboBox Name="BulkPlacementCombo" Width="140" VerticalAlignment="Center"
                          Margin="0,0,5,0"/>
                <Button Content="Apply to Selected" Click="ApplyPlacement_Click"
                        Padding="10,4"/>
            </StackPanel>

            <!-- Right side: action buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Link Selected" Click="LinkSelected_Click"
                        Padding="20,6" Margin="0,0,8,0"
                        FontWeight="Bold"
                        Background="#1A5276" Foreground="White"/>
                <Button Content="Cancel" Click="Cancel_Click"
                        Padding="20,6" IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>