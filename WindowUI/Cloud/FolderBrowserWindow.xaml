<Window x:Class="HMVTools.FolderBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HMV Tools - Select Folder"
        Width="550" Height="480"
        WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        FontFamily="Roboto, Arial, Segoe UI">

    <Border Background="White" BorderBrush="#C8C8D2" BorderThickness="1" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Grid Grid.Row="0" MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#004982" Offset="0.0"/>
                        <GradientStop Color="White" Offset="2.5"/>
                    </LinearGradientBrush>
                </Grid.Background>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="HMV " Foreground="White" FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text="Ingenieros" Foreground="#E9AA00" FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text=" | Select Folder" Foreground="White" FontSize="10" Margin="5,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="✕" Width="40" Background="Transparent" Foreground="#3C3C3C"
                        BorderThickness="0" FontSize="14" Cursor="Hand" Click="Cancel_Click"/>
            </Grid>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="20,14,20,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Breadcrumb -->
                <TextBlock Grid.Row="0" Name="BreadcrumbLabel"
                           FontSize="12" FontWeight="SemiBold" Foreground="#1E1E1E"
                           TextWrapping="Wrap" Margin="0,0,0,4"
                           Text="Select a project"/>

                <!-- Path hint -->
                <TextBlock Grid.Row="1" Name="PathLabel"
                           FontSize="10" Foreground="#999999"
                           TextWrapping="Wrap" Margin="0,0,0,8"
                           Text=""/>

                <!-- Folder list -->
                <Border Grid.Row="2"  BorderBrush="#C8C8D2" BorderThickness="1" ClipToBounds="True">
                    <ListBox Name="FolderList"
                             FontSize="12" Foreground="#3C3C3C"
                             BorderThickness="0"
                             MouseDoubleClick="FolderList_DoubleClick"
                             SelectionMode="Single"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Padding="4">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E8F3FF"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#D0E7FF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Border>
            </Grid>

            <!-- Bottom bar -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                <Button Name="BackButton" Content="← Back" Click="Back_Click" IsEnabled="False"
                        FontSize="10" Height="30" Width="80" Background="#F0F0F3" Foreground="#3C3C3C"
                        BorderThickness="0" Cursor="Hand" Margin="0,0,6,0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Content="Search .rvt here" Click="SearchHere_Click"
                        FontSize="10" FontWeight="Bold" Height="30" Width="120" Background="#E9AA00" Foreground="White"
                        BorderThickness="0" Cursor="Hand" Margin="0,0,6,0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Content="Cancel" Click="Cancel_Click"
                        FontSize="10" Height="30" Width="80" Background="#F0F0F3" Foreground="#3C3C3C"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>