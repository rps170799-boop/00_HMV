<Window x:Class="HMVTools.LinkedFilesAuditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HMV Tools - Linked Files Coordinate Audit"
        Height="700" Width="1600" MinWidth="1000" MinHeight="500"
        WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="Transparent"
        FontFamily="Roboto, Arial, Segoe UI">

    <Border Background="#F5F5F8" BorderBrush="#C8C8D2" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#004982" Offset="0.0"/>
                        <GradientStop Color="White" Offset="2.5"/>
                    </LinearGradientBrush>
                </Grid.Background>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="HMV " Foreground="White" FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text="Ingenieros" Foreground="#E9AA00" FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text=" - Link GIS Audit" Foreground="White" FontSize="10" Margin="5,2,0,0"/>
                </StackPanel>

                <Button Grid.Column="1" Content="✕" Width="40" Background="Transparent" Foreground="#3C3C3C" BorderThickness="0" FontSize="14" Cursor="Hand" Click="BtnClose_Click"/>
            </Grid>
            <Border Grid.Row="0" BorderBrush="#003366" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>

            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,15,0">
                        <TextBlock Text="Linked Files Coordinate Audit" FontSize="14" FontWeight="SemiBold" Foreground="#1E1E1E" Margin="0,0,0,4" TextWrapping="Wrap"/>
                        <TextBlock Text="Review GIS, descriptions, and coordinate data for all loaded Revit links." FontSize="11" Foreground="#787882" TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Search Link Name:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#1E1E1E" FontWeight="SemiBold"/>
                        <Border CornerRadius="6" BorderBrush="#C8C8D2" BorderThickness="1" Background="White">
                            <TextBox x:Name="searchBox" Width="220" Height="28" BorderThickness="0" Background="Transparent" Padding="8,0" VerticalContentAlignment="Center" TextChanged="SearchBox_TextChanged"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" Background="White" CornerRadius="8" BorderBrush="#EAEAEF" BorderThickness="1">
                    <ListView x:Name="dataListView" BorderThickness="0" Background="Transparent" Margin="2" FontSize="11">
                        <ListView.Resources>
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="Background" Value="#F8F8FA"/>
                                <Setter Property="Foreground" Value="#3C3C46"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="8,10"/>
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            </Style>
                        </ListView.Resources>
                    </ListView>
                </Border>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                    <Button Content="Export to Excel" FontSize="12" FontWeight="SemiBold" Height="36" Width="150" Background="#E9AA00" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnExport_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
